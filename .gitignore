# ==========================================
# 1. 环境变量与机密文件 (最高优先级)
# ==========================================
.env
.env.*
.claude             # AI 助手的本地配置或对话历史

# ==========================================
# 2. 前端环境 (Node.js / Vite / Vue 等)
# ==========================================
**/node_modules/
frontend/dist/
frontend/dist-ssr/
# 各种包管理器的崩溃日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# ==========================================
# 3. 后端环境 (Python)
# ==========================================
# 字节码与编译文件
__pycache__/
*.py[cod]
*$py.class

# 测试与代码质量工具的缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Python 打包产物
build/
dist/
wheels/
*.egg-info/
.eggs/

# 虚拟环境
.venv/
venv/
env/

# ==========================================
# 4. 数据库与本地数据存储
# ==========================================
*.sqlite
*.sqlite3
*.db
*.db3
*.db-journal
# 如果你的 data 文件夹用来存本地测试数据，最好忽略里面的内容
# (如果你想保留 data 文件夹本身，可以在 data 目录下建一个空的 .gitkeep 文件)
data/*
!data/.gitkeep

# ==========================================
# 5. 操作系统与编辑器
# ==========================================
# 操作系统自动生成的垃圾文件
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# VS Code 配置 (忽略本地状态，但允许共享团队代码规范配置)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

bug.txt
.claude/             # AI 助手的本地配置或对话历史
.agents/             # Agent 的本地配置或对话历史
docs/agents/                # 本地文档资料库
